# Staging copies of the other projects' source (regenerated by bin/kb; not ours to commit)
/repos/

# qmd local index (regenerable via bin/kb kb)
/.qmd/

# Generated route tables (regenerable via php artisan route:list)
/routes.*.json

# Generated graph artifacts — contain the indexed projects' code structure; not ours to commit.
# Regenerate locally with `make update`.
/graphify-out/

# Local project registry (real machine paths). Use kb.projects.toml.example as a template.
/kb.projects.toml

# Python bytecode
__pycache__/
*.pyc

# IDE
/.idea/
/.claude/settings.local.json

