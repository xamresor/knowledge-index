# SmartMonitor Knowledge Base — project registry (TEMPLATE).
# Copy to `kb.projects.toml` and edit for your machine; bin/kb reads it. No symlinks: paths are explicit.
# The real kb.projects.toml is gitignored so each checkout keeps its own local paths.
#
#   code  : directories rsynced (code-only) into repos/<name>/ and scanned by graphify
#   docs  : doc folder indexed by qmd into the unified "smartmonitor" collection
#   routes: optional — if set, this project is a Laravel app; bin/kb runs route:list
#           and links its frontend callers to its controllers
#   calls : optional — frontend source roots whose api.<verb>() calls target `serves`
#   serves: optional — repo tag whose controllers serve this project's `calls`

[[project]]
name   = "api"                       # Laravel API (route provider for webclient)
code   = ["/path/to/api/app", "/path/to/api/bootstrap", "/path/to/api/packages"]
docs   = "/path/to/api/storage/dox"
routes = "/path/to/api"

[[project]]
name   = "webclient"                 # Vue SPA — calls the api
code   = ["/path/to/webclient/src"]
docs   = "/path/to/webclient/docs"
calls  = ["/path/to/webclient/src"]
serves = "api"
