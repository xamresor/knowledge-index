#!/usr/bin/env bash
# Code Knowledge Base builder.
# Reads kb.projects.toml, builds per-project graphify graphs into repos/<name>/,
# merges them into one cross-repo graph, injects HTTP edges (frontend -> controllers),
# clusters + renders the full graph.html, and (re)indexes docs into qmd.
#
# Usage: bin/kb build | update | graph | kb | label | status | qmd-backend
set -euo pipefail

KB="$(cd "$(dirname "$0")/.." && pwd)"
cd "$KB"
PY=python3
CFG="$KB/kb.projects.toml"
OUT="$KB/graphify-out"
DOCS_STAGE="$KB/.docs"      # aggregated docs root for qmd (one collection = one path); gitignored
COLLECTION="${KB_COLLECTION:-kb}"
LOCAL_CFG="$KB/.kb.local"   # persisted local choices (e.g. QMD_BACKEND); gitignored
[ -f "$LOCAL_CFG" ] && . "$LOCAL_CFG"
export GRAPHIFY_VIZ_NODE_LIMIT="${GRAPHIFY_VIZ_NODE_LIMIT:-20000}"

require_cfg() {
  [ -f "$CFG" ] && return
  echo "error: $CFG not found." >&2
  echo "Copy the template first:  cp kb.projects.toml.example kb.projects.toml" >&2
  echo "then edit it with your projects' paths." >&2
  exit 1
}

# --- tiny TOML reader: emits "name|code(csv)|docs|routes|calls(csv)|serves" per project
read_projects() { "$PY" - "$CFG" <<'PY'
import re, sys
txt = open(sys.argv[1]).read()
blocks = re.split(r'(?m)^\[\[project\]\]\s*$', txt)[1:]
def val(b, k):
    m = re.search(rf'(?m)^\s*{k}\s*=\s*(.+)$', b)
    if not m: return ""
    raw = m.group(1).split('#',1)[0].strip()
    if raw.startswith('['):
        return ",".join(re.findall(r'"([^"]+)"', raw))
    return raw.strip('"')
for b in blocks:
    print("|".join(val(b,k) for k in ("name","code","docs","routes","calls","serves")))
PY
}

stage_and_build() {
  local name="$1" code_csv="$2"
  local dest="$KB/repos/$name"
  rm -rf "$dest"; mkdir -p "$dest"
  IFS=',' read -ra dirs <<< "$code_csv"
  for d in "${dirs[@]}"; do
    [ -d "$d" ] && rsync -a --exclude vendor --exclude node_modules --exclude storage \
      --exclude tests --exclude '*.png' --exclude '*.svg' --exclude '*.jpg' --exclude '*.jpeg' \
      --exclude '*.gif' --exclude '*.ico' --exclude '*.webp' "$d" "$dest/" 2>/dev/null || true
  done
  echo "  [$name] staged $(find "$dest" -type f \( -name '*.php' -o -name '*.js' -o -name '*.vue' -o -name '*.ts' -o -name '*.tsx' -o -name '*.py' \) | wc -l) source files"
  graphify update "$dest" >/dev/null 2>&1 || true
}

build_graph() {
  require_cfg
  echo "==> Building per-project graphs"
  local merge_inputs=() routes_specs=()
  while IFS='|' read -r name code docs routes calls serves; do
    [ -z "$name" ] && continue
    if [ -z "$code" ]; then
      echo "  [$name] docs-only — skipped from graph"
      continue
    fi
    stage_and_build "$name" "$code"
    merge_inputs+=("$KB/repos/$name/graphify-out/graph.json")
    [ -n "$routes" ] && env -C "$routes" php artisan route:list --json >"$KB/routes.$name.json" 2>/dev/null || true
    [ -n "$calls" ] && [ -n "$serves" ] && routes_specs+=("$serves|$calls")
  done < <(read_projects)

  echo "==> Merging into one cross-repo graph"
  mkdir -p "$OUT"
  if [ "${#merge_inputs[@]}" -ge 2 ]; then
    graphify merge-graphs "${merge_inputs[@]}" --out "$OUT/graph.json" >/dev/null
  else
    # a single-project KB is legitimate — merge-graphs needs >=2, so just adopt the one graph
    cp "${merge_inputs[0]}" "$OUT/graph.json"
  fi

  echo "==> Injecting HTTP edges (frontend -> controllers)"
  # re-walk config for calls/serves with their frontend roots
  while IFS='|' read -r name code docs routes calls serves; do
    [ -z "$calls" ] || [ -z "$serves" ] && continue
    IFS=',' read -ra fe <<< "$calls"
    "$PY" "$KB/bin/link_http.py" "$OUT/graph.json" "$KB/routes.$serves.json" "$serves" "${fe[@]}"
  done < <(read_projects)

  echo "==> Canonicalizing duplicate symbol/reference nodes"
  "$PY" "$KB/bin/dedupe.py" "$OUT/graph.json"
  echo "==> Decluttering framework god nodes (before clustering)"
  "$PY" "$KB/bin/declutter.py" "$OUT/graph.json" "$KB/kb.hubs.txt"
  echo "==> Clustering (locks final community ids)"
  graphify cluster-only "$KB" --no-label >/dev/null
  echo "==> Labeling communities by namespace/domain"
  "$PY" "$KB/bin/label_namespaces.py" "$OUT/graph.json" "$OUT/.graphify_labels.json" | head -1
  echo "==> Re-rendering report + full visualization with labels"
  graphify cluster-only "$KB" --no-label >/dev/null
  # final pass: ensure the labels file covers every community id in the rendered graph
  "$PY" "$KB/bin/label_namespaces.py" "$OUT/graph.json" "$OUT/.graphify_labels.json" >/dev/null

  echo "==> Enriching with node types, domains, db_table nodes + domain anchors"
  "$PY" "$KB/bin/enrich.py" "$OUT/graph.json" "$KB/repos"
  echo "==> Adding data-layer links (eloquent model rels, FK table->table, SQL code->table)"
  "$PY" "$KB/bin/link_data.py" "$OUT/graph.json" "$KB/repos"
  echo "==> Mining rationale comments (NOTE/WHY/HACK/SECURITY -> rationale nodes)"
  "$PY" "$KB/bin/link_rationale.py" "$OUT/graph.json" "$KB/repos"
  echo "==> Rendering custom typed/domain visualization"
  "$PY" "$KB/bin/render_viz.py" "$OUT/graph.json" "$OUT/kb-graph.html"
  echo "    graphify graph.html (fallback) + kb-graph.html (typed/domain) -> $OUT"
}

# Where qmd gets its vector embeddings. Resolved once and remembered in .kb.local.
#   none  - skip vectors; BM25 keyword search only (no model download)
#   llama - on-device llama.cpp embeddings (qmd default; downloads a small GGUF model)
#   other - bring your own: runs $KB_QMD_EMBED_CMD if set, else plain `qmd embed`
#           (point qmd at your own model/endpoint via its env)
# Precedence: KB_QMD_BACKEND env > persisted QMD_BACKEND > interactive prompt > llama.
resolve_qmd_backend() {
  local b="${KB_QMD_BACKEND:-${QMD_BACKEND:-}}"
  if [ -z "$b" ]; then
    if [ -t 0 ]; then
      {
        echo "Where should qmd plug its embeddings?"
        echo "  none  - skip vectors; BM25 keyword search only (no model download)"
        echo "  llama - on-device llama.cpp embeddings (qmd default; downloads a small model)"
        echo "  other - configure qmd yourself, or set KB_QMD_EMBED_CMD"
      } >&2
      local ans; read -rp "  [none|llama|other] (llama): " ans </dev/tty || ans=""
      b="${ans:-llama}"
    else
      b="llama"   # non-interactive (CI, hooks): default to the on-device backend
    fi
  fi
  case "$b" in none|llama|other) ;; *) b="llama" ;; esac
  # persist the resolved choice (env override is not persisted — it's a one-off)
  if [ -z "${KB_QMD_BACKEND:-}" ] && [ "${QMD_BACKEND:-}" != "$b" ]; then
    printf 'QMD_BACKEND=%s\n' "$b" > "$LOCAL_CFG"
  fi
  QMD_BACKEND="$b"
  echo "$b"
}

qmd_embed() {
  local b; b="$(resolve_qmd_backend)"
  case "$b" in
    none)  echo "    qmd backend=none — skipping embeddings (BM25 keyword search only)" ;;
    other) if [ -n "${KB_QMD_EMBED_CMD:-}" ]; then
             echo "    qmd backend=other — running KB_QMD_EMBED_CMD"; eval "$KB_QMD_EMBED_CMD" || true
           else
             echo "    qmd backend=other — running 'qmd embed' (configure qmd's model/endpoint via its env)"
             qmd embed 2>/dev/null || true
           fi ;;
    llama) qmd embed 2>/dev/null || true ;;
  esac
}

build_kb() {
  require_cfg
  echo "==> Staging + indexing docs into qmd collection '$COLLECTION'"
  [ -d "$KB/.qmd" ] || qmd init >/dev/null 2>&1 || true
  # qmd binds one collection to a single root path, so aggregate every project's
  # docs under one staged root ($DOCS_STAGE/<project>/...) and index that — otherwise
  # only the first project's docs would be searchable.
  rm -rf "$DOCS_STAGE"; mkdir -p "$DOCS_STAGE"
  local staged=0
  while IFS='|' read -r name code docs routes calls serves; do
    [ -z "$docs" ] || [ ! -d "$docs" ] && continue
    mkdir -p "$DOCS_STAGE/$name"
    rsync -a --prune-empty-dirs \
      --exclude='node_modules/' --exclude='.git/' --exclude='vendor/' \
      --include='*/' --include='*.md' --exclude='*' \
      "$docs/" "$DOCS_STAGE/$name/" 2>/dev/null || true
    # Sanitize the staged copy to ASCII: qmd 0.3.2's chunker slices on byte offsets and
    # panics on multibyte UTF-8 at a chunk boundary. Only this staged mirror is touched —
    # the project's own docs are never modified.
    "$PY" - "$DOCS_STAGE/$name" <<'PY'
import sys, unicodedata, pathlib
root = pathlib.Path(sys.argv[1])
for p in root.rglob("*.md"):
    s = p.read_text(encoding="utf-8", errors="ignore")
    # decompose accents then drop anything outside ASCII (emoji, dashes, smart quotes)
    clean = unicodedata.normalize("NFKD", s).encode("ascii", "ignore").decode("ascii")
    if clean != s:
        p.write_text(clean, encoding="utf-8")
PY
    echo "  [$name] staged $(find "$DOCS_STAGE/$name" -name '*.md' | wc -l) docs"
    staged=1
  done < <(read_projects)
  [ "$staged" = 1 ] || { echo "  (no docs configured)"; return; }
  # point the single collection at the aggregated root; re-point only if it changed
  local cur; cur="$(qmd collection show "$COLLECTION" 2>/dev/null | awk -F': *' '/Path:/{print $2; exit}')"
  if [ "$cur" != "$DOCS_STAGE" ]; then
    qmd collection remove "$COLLECTION" >/dev/null 2>&1 || true
    qmd collection add "$DOCS_STAGE" --name "$COLLECTION" >/dev/null 2>&1 || true
  fi
  qmd update 2>/dev/null || true
  qmd_embed
  qmd status || true
}

case "${1:-build}" in
  build)  build_graph; build_kb ;;
  graph)  build_graph ;;
  kb)     build_kb ;;
  update) build_graph; qmd update >/dev/null 2>&1 || true; qmd_embed; echo "refreshed" ;;
  qmd-backend) rm -f "$LOCAL_CFG"; unset QMD_BACKEND; echo "qmd backend set to: $(resolve_qmd_backend)" ;;
  label)  "$PY" "$KB/bin/label_namespaces.py" "$OUT/graph.json" "$OUT/.graphify_labels.json"
          graphify cluster-only "$KB" --no-label >/dev/null; echo "relabeled + report regenerated" ;;
  status) graphify diagnose multigraph --graph "$OUT/graph.json" | head -8; echo; qmd status ;;
  *) echo "usage: bin/kb {build|graph|kb|update|label|status|qmd-backend}"; exit 1 ;;
esac
